{
  "name": "@synap-js/cli",
  "version": "0.0.18",
  "type": "module",
  "description": "CLI for the Synap framework",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "synap": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/bin.ts src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@libsql/client": "^0.17.2",
    "@synap-js/core": "workspace:*",
    "@synap-js/generators": "workspace:*",
    "@synap-js/runtime": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.0"
  }
}
